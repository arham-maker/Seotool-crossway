# Copy to .env.local and fill in values. Never commit real secrets.
#
# Prisma CLI only loads `.env` by default. This repo’s npm scripts run Prisma via
# `scripts/prisma-with-local-env.mjs`, which loads `.env` then `.env.local`, so
# `DATABASE_URL` in `.env.local` works for: npm run prisma:deploy, prisma:push, etc.

# --- Core (required in production) ---
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32-min-32-chars"

# --- Google (Search Console / PageSpeed) ---
# Path to service account JSON file (repo-relative) OR inline JSON string for serverless:
GOOGLE_APPLICATION_CREDENTIALS_JSON="./credentials/your-service-account.json"
PAGESPEED_API_KEY=""

# --- Email (password reset, verification) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# --- SMM / GTM ingestion ---
# Required in production for POST /api/smm/collect (GTM webhook)
SMM_COLLECT_SECRET=""

# --- Optional: auto-fetch social metrics (Super Admin) ---
YOUTUBE_API_KEY=""
META_APP_ACCESS_TOKEN=""
META_PAGE_ACCESS_TOKEN=""
META_APP_ID=""
META_APP_SECRET=""
# TikTok — https://developers.tiktok.com/ → Manage apps → create app → Credentials (Client key + secret).
# Enable product "Research API" on the app and apply for access (scope research.data.basic) for @username follower lookup.
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# --- Ops ---
# LOG_LEVEL=INFO
# DOCKER_BUILD=1
# (set DOCKER_BUILD=1 only when building a Docker image that expects output: standalone)
