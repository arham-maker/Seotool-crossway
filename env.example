# MySQL Connection String (Prisma)
# Local XAMPP example:
# DATABASE_URL=mysql://root:YOUR_PASSWORD@127.0.0.1:3306/crossway_tool
# Production example:
# DATABASE_URL=mysql://app_user:APP_PASSWORD@db-host:3306/crossway_tool
DATABASE_URL=mysql://root:YOUR_PASSWORD@127.0.0.1:3306/crossway_tool

# NextAuth Configuration
# Generate secret with: openssl rand -base64 32
# For development, this is optional (will use fallback)
# For production, this is REQUIRED
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# PageSpeed Insights API Key
# Get from: https://console.cloud.google.com/apis/credentials
# For development, this is optional
# For production, this is REQUIRED
PAGESPEED_API_KEY=

# Optional: Google Analytics Configuration
# Path to service account JSON file or inline JSON
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Optional: Logging Level (ERROR, WARN, INFO, DEBUG)
LOG_LEVEL=INFO

# SMTP Email Configuration (for email verification and notifications)
# If not set, emails will be logged to console in development
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use App Password
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587
# For Mailgun: SMTP_HOST=smtp.mailgun.org, SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Node Environment (usually set automatically)
NODE_ENV=development

